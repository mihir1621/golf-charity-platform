{
  "version": 2,
  "name": "clubhouse-api",
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/app.ts"
    },
    {
      "source": "/health",
      "destination": "src/app.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
