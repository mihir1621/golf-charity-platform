{
  "version": 2,
  "builds": [
    {
       "src": "backend/src/app.ts",
       "use": "@vercel/node"
    },
    {
       "src": "frontend/package.json",
       "use": "@vercel/static-build",
       "config": {
         "distDir": "dist"
       }
    }
  ],
  "rewrites": [
    {
       "source": "/api/(.*)",
       "destination": "/backend/src/app.ts"
    },
    {
       "source": "/health",
       "destination": "/backend/src/app.ts"
    },
    {
       "source": "/assets/(.*)",
       "destination": "/frontend/assets/$1"
    },
    {
       "source": "/((?!api|health|assets|favicon.ico).*)",
       "destination": "/frontend/index.html"
    }
  ]
}
